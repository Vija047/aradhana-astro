# AstroAgent Backend Environment Variables Template
# Copy this file to .env and fill in the actual keys for local development.
# For production deployment (e.g. Render), configure these in your service environment settings.

# Express Server Port
PORT=5000

# Node Environment (production / development / test)
NODE_ENV=production

# OpenAI API Key (required for LLM & Embeddings)
OPENAI_API_KEY=your_openai_api_key

# MongoDB Connection URI (conversation persistence)
# Local example: mongodb://localhost:27017/astroagent
# Production example: mongodb+srv://<username>:<password>@cluster0.xxxx.mongodb.net/astroagent?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017/astroagent

# Pinecone Vector Database Config (for RAG knowledge lookup)
PINECONE_API_KEY=your_pinecone_api_key
PINECONE_INDEX_NAME=astro-db
